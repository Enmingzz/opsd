+# OPSD official-first4 AOKVQA adapters. Appended as an override so both the clear
+# names and the older convenience aliases use the same official VisionZip eval path.
+# Official split: 5%=0% dominant+5% contextual, 10%=5%+5%, 20%=15%+5%, 30%=25%+5%.
+import os as _opsd_os
+_OPSD_BASE_ROOT = _opsd_os.environ.get('OPSD_BASE_ROOT', '/root/autodl-tmp/opsd_eval')
+_OPSD_FIRST4_RUN_ID = _opsd_os.environ.get('OPSD_FIRST4_RUN_ID', 'aokvqa_first4_officialvz_20260610_154040')
+_OPSD_FIRST4_ROOT = _opsd_os.environ.get(
+    'OPSD_FIRST4_CKPT_ROOT',
+    f'{_OPSD_BASE_ROOT}/outputs/visionzip_aokvqa_reasoning/checkpoints/{_OPSD_FIRST4_RUN_ID}',
+)
+_OPSD_OFFICIAL_VISIONZIP_ROOT = _opsd_os.environ.get(
+    'VISIONZIP_QWEN25VL_ROOT',
+    f'{_OPSD_BASE_ROOT}/VisionZip/Qwen2_5_VL',
+)
+_OPSD_FIRST4_ADAPTERS = {
+    'sft': f'{_OPSD_FIRST4_ROOT}/01_sft_official_gbs8/final',
+    'epic': f'{_OPSD_FIRST4_ROOT}/02_epic_tcd_full_teacher_official_gbs8/final',
+    'ema_nogt': f'{_OPSD_FIRST4_ROOT}/03_ema_opsd_nogt_official_gbs8/final',
+    'freeze_sftteacher_nogt': f'{_OPSD_FIRST4_ROOT}/04_freeze_sft_teacher_opsd_nogt_official_gbs8/final',
+}
+_OPSD_OFFICIAL_VISIONZIP_RATIOS = {
+    'r005': (0.00, 0.05),
+    'r010': (0.05, 0.05),
+    'r020': (0.15, 0.05),
+    'r030': (0.25, 0.05),
+}
+
+def _opsd_first4_official_adapter(adapter_key, ratio_key):
+    dominant, contextual = _OPSD_OFFICIAL_VISIONZIP_RATIOS[ratio_key]
+    return partial(
+        vlm.Qwen25VLOfficialVisionZipChat,
+        model_path='Qwen/Qwen2.5-VL-7B-Instruct',
+        min_pixels=1280 * 28 * 28,
+        max_pixels=16384 * 28 * 28,
+        use_custom_prompt=False,
+        attn_implementation='flash_attention_2',
+        visionzip_root=_OPSD_OFFICIAL_VISIONZIP_ROOT,
+        visionzip_dominant_ratio=dominant,
+        visionzip_contextual_ratio=contextual,
+        default_max_new_tokens=32,
+        adapter_path=_OPSD_FIRST4_ADAPTERS[adapter_key],
+    )
+
+_OPSD_FIRST4_OFFICIAL_MODELS = {}
+for _adapter_key in _OPSD_FIRST4_ADAPTERS:
+    for _ratio_key in _OPSD_OFFICIAL_VISIONZIP_RATIOS:
+        _OPSD_FIRST4_OFFICIAL_MODELS[f'opsd_first4_officialvz_{_adapter_key}_{_ratio_key}'] = _opsd_first4_official_adapter(_adapter_key, _ratio_key)
+
+# Backward-compatible aliases. These used to point to older non-official training
+# outputs; keep the names but make them resolve to the current official run.
+for _ratio_key in _OPSD_OFFICIAL_VISIONZIP_RATIOS:
+    _OPSD_FIRST4_OFFICIAL_MODELS[f'opsd_aokvqa_sft_final_{_ratio_key}'] = _opsd_first4_official_adapter('sft', _ratio_key)
+    _OPSD_FIRST4_OFFICIAL_MODELS[f'opsd_aokvqa_epic_final_{_ratio_key}'] = _opsd_first4_official_adapter('epic', _ratio_key)
+    _OPSD_FIRST4_OFFICIAL_MODELS[f'opsd_aokvqa_ema_nogt_final_{_ratio_key}'] = _opsd_first4_official_adapter('ema_nogt', _ratio_key)
+    _OPSD_FIRST4_OFFICIAL_MODELS[f'opsd_aokvqa_freeze_sftteacher_final_{_ratio_key}'] = _opsd_first4_official_adapter('freeze_sftteacher_nogt', _ratio_key)
