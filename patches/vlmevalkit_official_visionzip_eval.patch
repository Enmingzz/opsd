+        attn_implementation='flash_attention_2',
+        max_new_tokens=128,
+    ),
+})
+
+# OPSD MMStar additional alignment configs: HF default processor bounds and custom 2048 generation.
+supported_VLM.update({
+    'opsd_qwen25vl_official_7b_flashattn2_mmstar_hfdefault_mnt128': partial(
+        vlm.Qwen2VLChat,
+        model_path='Qwen/Qwen2.5-VL-7B-Instruct',
+        use_custom_prompt=True,
+        attn_implementation='flash_attention_2',
+        max_new_tokens=128,
+    ),
+    'opsd_qwen25vl_official_7b_flashattn2_mmstar_hfdefault_nocustom_mnt128': partial(
