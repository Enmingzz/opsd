diff --git a/vlmeval/vlm/qwen2_vl/visionzip_official.py b/vlmeval/vlm/qwen2_vl/visionzip_official.py
new file mode 100644
index 0000000..7e669ca
--- /dev/null
+++ b/vlmeval/vlm/qwen2_vl/visionzip_official.py
@@ -0,0 +1,220 @@
+from __future__ import annotations
+
+import importlib.util
+import os
+import sys
+from pathlib import Path
+from typing import Any
+
+import torch
+from PIL import ImageFile
+
+ImageFile.LOAD_TRUNCATED_IMAGES = True
+
+from .model import Qwen2VLChat
+
+
+def _load_official_visionzip_class(visionzip_root: str | os.PathLike[str]):
+    module_path = Path(visionzip_root) / 'qwen2_5vl_visionzip.py'
+    if not module_path.exists():
+        raise FileNotFoundError(f'Official VisionZip Qwen2.5-VL file not found: {module_path}')
+    module_name = 'vlmeval_official_qwen25vl_visionzip'
+    existing = sys.modules.get(module_name)
+    if existing is not None and hasattr(existing, 'Qwen2_5_VLForConditionalGeneration'):
+        return existing.Qwen2_5_VLForConditionalGeneration
+    spec = importlib.util.spec_from_file_location(module_name, module_path)
+    if spec is None or spec.loader is None:
+        raise ImportError(f'Could not load module spec for {module_path}')
+    module = importlib.util.module_from_spec(spec)
+    sys.modules[module_name] = module
+    spec.loader.exec_module(module)
+    return module.Qwen2_5_VLForConditionalGeneration
+
+
+class Qwen25VLOfficialVisionZipChat(Qwen2VLChat):
+    INSTALL_REQ = False
+    INTERLEAVE = True
+    VIDEO_LLM = False
+
+    def __init__(
+        self,
+        visionzip_root: str | None = None,
+        visionzip_dominant_ratio: float = 0.65,
+        visionzip_contextual_ratio: float = 0.05,
+        default_max_new_tokens: int = 32,
+        adapter_path: str | None = None,
+        **kwargs: Any,
+    ) -> None:
+        self.visionzip_root = visionzip_root or os.environ.get(
+            'VISIONZIP_QWEN25VL_ROOT',
+            '/root/autodl-tmp/opsd_eval/VisionZip/Qwen2_5_VL',
+        )
+        env_min_pixels = os.environ.get('VISIONZIP_MIN_PIXELS')
+        env_max_pixels = os.environ.get('VISIONZIP_MAX_PIXELS')
+        if env_min_pixels:
+            kwargs['min_pixels'] = int(env_min_pixels)
+        if env_max_pixels:
+            kwargs['max_pixels'] = int(env_max_pixels)
+
+        self.visionzip_dominant_ratio = float(visionzip_dominant_ratio)
+        self.visionzip_contextual_ratio = float(visionzip_contextual_ratio)
+        self.visionzip_default_max_new_tokens = int(default_max_new_tokens)
+        self.adapter_path = adapter_path or os.environ.get('VISIONZIP_ADAPTER_PATH', '')
+
+        official_cls = _load_official_visionzip_class(self.visionzip_root)
+        import transformers
+
+        old_cls = getattr(transformers, 'Qwen2_5_VLForConditionalGeneration', None)
+        transformers.Qwen2_5_VLForConditionalGeneration = official_cls
+        kwargs.setdefault('attn_implementation', 'flash_attention_2')
+        kwargs.setdefault('max_new_tokens', self.visionzip_default_max_new_tokens)
+        try:
+            super().__init__(**kwargs)
+        finally:
+            if old_cls is None:
+                try:
+                    delattr(transformers, 'Qwen2_5_VLForConditionalGeneration')
+                except AttributeError:
+                    pass
+            else:
+                transformers.Qwen2_5_VLForConditionalGeneration = old_cls
+
+        self._apply_visionzip_runtime_config()
+        if self.adapter_path:
+            import peft.utils.save_and_load as peft_save_and_load
+            from peft import PeftModel
+
+            peft_save_and_load._maybe_shard_state_dict_for_tp = lambda *args, **kwargs: None
+            if not Path(self.adapter_path).exists():
+                raise FileNotFoundError(f'LoRA adapter path not found: {self.adapter_path}')
+            self.model = PeftModel.from_pretrained(self.model, self.adapter_path)
+            self.model.eval()
+            self._apply_visionzip_runtime_config()
+        self.generate_kwargs['use_cache'] = False
+        self.model.generation_config.use_cache = False
+
+    def _model_candidates(self):
+        seen = set()
+        stack = [self.model]
+        while stack:
+            obj = stack.pop(0)
+            if obj is None or id(obj) in seen:
+                continue
+            seen.add(id(obj))
+            yield obj
+            for name in ('base_model', 'model'):
+                child = getattr(obj, name, None)
+                if child is not None and id(child) not in seen:
+                    stack.append(child)
+
+    def _apply_visionzip_runtime_config(self) -> None:
+        for obj in self._model_candidates():
+            try:
+                obj.visionzip_dominant_ratio = self.visionzip_dominant_ratio
+                obj.visionzip_contextual_ratio = self.visionzip_contextual_ratio
+                if getattr(obj, 'generation_config', None) is not None:
+                    obj.generation_config.use_cache = False
+            except Exception:
+                pass
+
+    def _last_pruned_inputs(self):
+        for obj in self._model_candidates():
+            pruned = getattr(obj, '_last_visionzip_pruned_inputs', None)
+            if pruned is not None:
+                return pruned
+        return None
+
+    @staticmethod
+    def _dataset_max_new_tokens(dataset: str | None, default: int) -> int:
+        name = (dataset or '').lower()
+        if 'mme' in name or 'pope' in name:
+            return 16
+        if 'mmstar' in name:
+            return int(os.environ.get('VISIONZIP_MMSTAR_MAX_NEW_TOKENS', default))
+        return int(default)
+
+    def _decode_generated(self, generated: list[torch.Tensor]) -> str:
+        if not generated:
+            return ''
+        gen_ids = torch.cat(generated, dim=1)
+        return self.processor.tokenizer.batch_decode(
+            gen_ids, skip_special_tokens=True, clean_up_tokenization_spaces=False
+        )[0]
+
+    def _post_process_response(self, response: str) -> str:
+        if not self.post_process:
+            return response
+        resp = response.split('\boxed{')[-1]
+        counter, end = 1, None
+        for i, ch in enumerate(resp):
+            if ch == '{':
+                counter += 1
+            elif ch == '}':
+                counter -= 1
+            if counter == 0:
+                end = i
+                break
+            if i == len(resp) - 1:
+                end = len(resp)
+        return resp[:end] if end is not None else response
+
+    def generate_inner(self, message, dataset=None):
+        try:
+            from qwen_vl_utils import process_vision_info
+        except Exception as err:
+            raise RuntimeError("qwen_vl_utils not found, please install it via 'pip install qwen-vl-utils'") from err
+
+        messages = []
+        if self.system_prompt is not None:
+            messages.append({'role': 'system', 'content': self.system_prompt})
+        messages.append({'role': 'user', 'content': self._prepare_content(message, dataset=dataset)})
+        if self.verbose:
+            print(f'\033[31m{messages}\033[0m')
+
+        text = self.processor.apply_chat_template([messages], tokenize=False, add_generation_prompt=True)
+        images, videos = process_vision_info([messages])
+        inputs = self.processor(text=text, images=images, videos=videos, padding=True, return_tensors='pt')
+        inputs = inputs.to('cuda')
+
+        max_new_tokens = self._dataset_max_new_tokens(dataset, self.visionzip_default_max_new_tokens)
+        eos_token_id = self.processor.tokenizer.eos_token_id
+        embed_tokens = self.model.get_input_embeddings()
+
+        with torch.no_grad():
+            outputs = self.model(**inputs, use_cache=False, return_dict=True)
+            pruned = self._last_pruned_inputs()
+            if pruned is None:
+                raise RuntimeError('Official VisionZip forward did not expose pruned prompt tensors.')
+            input_ids = pruned['input_ids'].clone()
+            inputs_embeds = pruned['inputs_embeds'].clone()
+            attention_mask = pruned['attention_mask'].clone()
+            position_ids = pruned['position_ids'].clone()
+            generated: list[torch.Tensor] = []
+
+            for step in range(int(max_new_tokens)):
+                next_token = torch.argmax(outputs.logits[:, -1, :], dim=-1, keepdim=True)
+                generated.append(next_token)
+                if eos_token_id is not None and int(next_token.item()) == int(eos_token_id):
+                    break
+                input_ids = torch.cat([input_ids, next_token.to(device=input_ids.device, dtype=input_ids.dtype)], dim=1)
+                next_embed = embed_tokens(next_token.to(device=inputs_embeds.device)).to(dtype=inputs_embeds.dtype)
+                inputs_embeds = torch.cat([inputs_embeds, next_embed], dim=1)
+                one = torch.ones((attention_mask.shape[0], 1), device=attention_mask.device, dtype=attention_mask.dtype)
+                attention_mask = torch.cat([attention_mask, one], dim=1)
+                position_ids = torch.cat([position_ids, position_ids[:, :, -1:] + 1], dim=2)
+                if step == int(max_new_tokens) - 1:
+                    break
+                outputs = self.model(
+                    input_ids=input_ids,
+                    inputs_embeds=inputs_embeds,
+                    attention_mask=attention_mask,
+                    position_ids=position_ids,
+                    use_cache=False,
+                    return_dict=True,
+                )
+
+        response = self._decode_generated(generated).strip()
+        response = self._post_process_response(response)
+        if self.verbose:
+            print(f'\033[32m{response}\033[0m')
+        return response
