+        model_path='Qwen/Qwen2.5-VL-7B-Instruct',
+        use_custom_prompt=False,
+        attn_implementation='flash_attention_2',
+        max_new_tokens=128,
+    ),
+    'opsd_qwen25vl_official_7b_flashattn2_mmstar_custom_mnt2048': partial(
+        vlm.Qwen2VLChat,
+        model_path='Qwen/Qwen2.5-VL-7B-Instruct',
+        min_pixels=1280 * 28 * 28,
+        max_pixels=16384 * 28 * 28,
+        use_custom_prompt=True,
+        attn_implementation='flash_attention_2',
+        max_new_tokens=2048,
+    ),
+})
+
+# OPSD MMStar official VisionZip/adapters aligned configs.
+# MMStar baseline alignment used custom MCQ prompt + max_new_tokens=2048:
+# Qwen2.5-VL-7B no prune = 61.47, close to reported 62.3 in the pruning table.
+def _opsd_vz_mmstar_model(ratio_key):
+    dominant, contextual = _OPSD_OFFICIAL_VISIONZIP_RATIOS[ratio_key]
+    return partial(
+        vlm.Qwen25VLOfficialVisionZipChat,
+        model_path='Qwen/Qwen2.5-VL-7B-Instruct',
+        min_pixels=1280 * 28 * 28,
+        max_pixels=16384 * 28 * 28,
+        use_custom_prompt=True,
+        attn_implementation='flash_attention_2',
+        visionzip_root=_OPSD_OFFICIAL_VISIONZIP_ROOT,
+        visionzip_dominant_ratio=dominant,
+        visionzip_contextual_ratio=contextual,
+        default_max_new_tokens=2048,
+    )
+
+def _opsd_first4_mmstar_adapter(adapter_key, ratio_key):
+    dominant, contextual = _OPSD_OFFICIAL_VISIONZIP_RATIOS[ratio_key]
+    return partial(
+        vlm.Qwen25VLOfficialVisionZipChat,
+        model_path='Qwen/Qwen2.5-VL-7B-Instruct',
+        min_pixels=1280 * 28 * 28,
+        max_pixels=16384 * 28 * 28,
+        use_custom_prompt=True,
+        attn_implementation='flash_attention_2',
+        visionzip_root=_OPSD_OFFICIAL_VISIONZIP_ROOT,
+        visionzip_dominant_ratio=dominant,
+        visionzip_contextual_ratio=contextual,
+        default_max_new_tokens=2048,
+        adapter_path=_OPSD_FIRST4_ADAPTERS[adapter_key],
+    )
+
+_OPSD_MMSTAR_ALIGNED_MODELS = {}
+for _ratio_key in _OPSD_OFFICIAL_VISIONZIP_RATIOS:
+    _OPSD_MMSTAR_ALIGNED_MODELS['opsd_qwen25vl_visionzip_mmstar_' + _ratio_key] = _opsd_vz_mmstar_model(_ratio_key)
+for _adapter_key in _OPSD_FIRST4_ADAPTERS:
+    for _ratio_key in _OPSD_OFFICIAL_VISIONZIP_RATIOS:
+        _OPSD_MMSTAR_ALIGNED_MODELS['opsd_first4_officialvz_' + _adapter_key + '_mmstar_' + _ratio_key] = _opsd_first4_mmstar_adapter(_adapter_key, _ratio_key)
+
+supported_VLM.update(_OPSD_MMSTAR_ALIGNED_MODELS)
+
